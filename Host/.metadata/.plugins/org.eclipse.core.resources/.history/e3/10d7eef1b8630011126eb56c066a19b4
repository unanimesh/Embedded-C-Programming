int math_add(int a, int b)
{
    return a + b;
}
int math_subtract(int a, int b)
{
    return a - b;
}
long long int math_multiply(int a, int b)
{
    return (long long int)a * b;
}
float math_divide(int a, int b)
{
    return a / b;
}
